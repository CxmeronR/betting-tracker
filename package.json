{
  "name": "betting-tracker",
  "version": "1.0.15",
  "description": "Professional sports betting analytics dashboard",
  "main": "electron/main.js",
  "author": "Cameron",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "build:mac": "vite build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac",
    "build:mac:universal": "vite build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --universal",
    "postinstall": "electron-builder install-app-deps",
    "publish": "vite build && electron-builder --mac --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "electron-log": "^5.2.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.1.0",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.cameron.betting-tracker",
    "productName": "Betting Tracker",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.finance",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "afterPack": "./scripts/ad-hoc-sign.js",
    "dmg": {
      "title": "Betting Tracker",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "CxmeronR",
      "repo": "betting-tracker",
      "releaseType": "release"
    }
  }
}
